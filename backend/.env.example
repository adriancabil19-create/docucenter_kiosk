# Server
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# CORS — comma-separated list of allowed origins
# Include the admin console URL here too:
#   ALLOWED_ORIGINS=http://localhost:3000,https://your-admin.onrender.com
ALLOWED_ORIGINS=http://localhost:3000

# Security (set to true to enable)
ENABLE_HELMET=true
ENABLE_CORS=true
CORS_CREDENTIALS=false

# SQLite — leave blank to use default path (project root/docucenter.db)
# On Render with a persistent disk mounted at /data:
#   DATABASE_PATH=/data/docucenter.db
DATABASE_PATH=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# PayMongo (required in production)
PAYMONGO_API_KEY=pk_test_YOUR_API_KEY
PAYMONGO_MERCHANT_ID=your_merchant_id
PAYMONGO_SECRET_KEY=sk_test_YOUR_SECRET_KEY
PAYMONGO_PUBLIC_KEY=pk_test_YOUR_PUBLIC_KEY
PAYMONGO_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Payment timing
PAYMENT_TIMEOUT_SECONDS=300
PAYMENT_POLLING_INTERVAL_MS=3000

# Print
# Leave PRINTER_NAME empty to use the system default printer
PRINT_SIMULATION_ENABLED=false
PRINTER_NAME=Brother MFC-J2730DW Printer

# Logging
LOG_LEVEL=info

# Aiven / PostgreSQL (optional — for QR verification)
AIVEN_DATABASE_URL=
AIVEN_DB_USER=
AIVEN_DB_PASSWORD=
AIVEN_REQUIRE_SSL=false
