# Server
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Security (set to true to enable)
ENABLE_HELMET=true
ENABLE_CORS=true
CORS_CREDENTIALS=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# GCash (required in production)
GCASH_MERCHANT_ID=your_merchant_id
GCASH_API_KEY=your_api_key
GCASH_SECRET_KEY=your_secret_key
GCASH_WEBHOOK_SECRET=your_webhook_secret
GCASH_API_BASE_URL=https://api.gcash.com

# Payment timing
PAYMENT_TIMEOUT_SECONDS=300
PAYMENT_POLLING_INTERVAL_MS=3000

# Print
# Leave PRINTER_NAME empty to use the system default printer
PRINT_SIMULATION_ENABLED=false
PRINTER_NAME=Brother MFC-J2730DW Printer

# Logging
LOG_LEVEL=info

# Aiven / PostgreSQL (optional — for QR verification)
AIVEN_DATABASE_URL=
AIVEN_DB_USER=
AIVEN_DB_PASSWORD=
AIVEN_REQUIRE_SSL=false
